# Copy to .env (gitignored) and set real values before `docker compose up`.
# The backend refuses to boot in production on a placeholder or short (<32 char)
# secret, or a wildcard CORS origin — so these MUST be real, random values.

# Mongo root credentials (the backend connects with authSource=admin).
MONGO_ROOT_USERNAME=kavach
MONGO_ROOT_PASSWORD=change-me-to-a-strong-password

# Auth secrets — generate with e.g. `openssl rand -hex 32`.
JWT_SECRET=
JWT_REFRESH_SECRET=

# Shared secret devices present to authenticate MQTT telemetry (fail-closed).
DEVICE_SECRET=

# The public origin the app is served from (nginx). Used for CORS + the client
# bundle's API/socket base URL. Set to your real domain in production.
PUBLIC_ORIGIN=http://localhost

# Optional: turn the dev-only labeled simulator on for a live demo (default off).
ENABLE_SENSOR_SIMULATION=false
IOT_ENABLED=true
