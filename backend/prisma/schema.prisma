generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Machine {
  id              String      @id @default(cuid())
  name            String
  type            String
  location        String

  status          String      @default("Running")

  temperature     Float
  vibration       Float
  power           Float
  efficiency      Float
  health          Float

  lastUpdated     DateTime    @updatedAt

  alerts          Alert[]
  maintenance     Maintenance[]
  sensorData      SensorData[]
}

model Alert {
  id          String      @id @default(cuid())

  severity    String
  message     String

  createdAt   DateTime    @default(now())

  machineId   String
  machine     Machine      @relation(fields: [machineId], references: [id])
}

model Maintenance {
  id              String      @id @default(cuid())

  nextService     DateTime
  completed       Boolean     @default(false)

  machineId       String
  machine         Machine     @relation(fields: [machineId], references: [id])
}

model SensorData {
  id              String      @id @default(cuid())

  temperature     Float
  vibration       Float
  power           Float

  createdAt       DateTime    @default(now())

  machineId       String
  machine         Machine     @relation(fields: [machineId], references: [id])
}