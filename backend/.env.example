MONGO_URI=mongodb://localhost:27017/kavach
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=replace-with-a-second-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
PORT=5000
CORS_ORIGIN=http://localhost:3000
# Dev-only telemetry simulator. When off, sim readings are never counted as live.
ENABLE_SENSOR_SIMULATION=false
SENSOR_INTERVAL_MS=1000
# Set true to connect the MQTT subscriber and ingest real device telemetry.
IOT_ENABLED=false
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=kavach-backend
MQTT_KEEPALIVE=60
MQTT_RECONNECT_MS=2000
# Shared secret every device must present to publish telemetry. Ingest fails
# CLOSED: if this is unset, all device telemetry is rejected (no fail-open).
DEVICE_SECRET=replace-with-device-shared-secret
DEVICE_OFFLINE_AFTER_MS=45000
DEVICE_HEARTBEAT_MONITOR_MS=15000
LIVE_TELEMETRY_STALE_MS=30000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
ENERGY_COST_PER_KWH=0.12
CARBON_KG_PER_KWH=0.42
AI_PROVIDER=local-rule-engine
OPENAI_MODEL=future-openai-compatible
COMPANY_NAME=KAVACH Industrial Operations
COMPANY_SITE=Primary Plant
COMPANY_INDUSTRY=Industrial Manufacturing
COMPANY_TIMEZONE=Asia/Calcutta
