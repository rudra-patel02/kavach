NODE_ENV=production
PORT=5000
API_VERSION=20.0.0

MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>
MONGO_MAX_POOL_SIZE=20

JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-second-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

CORS_ORIGIN=https://kavach-1-7749.onrender.com
CORS_CREDENTIALS=true
PUBLIC_API_BASE_URL=https://your-backend-domain.example

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=25
BRUTE_FORCE_WINDOW_MS=900000
BRUTE_FORCE_MAX_FAILURES=8
COMPRESSION_THRESHOLD_BYTES=1024

IOT_ENABLED=false
ENABLE_SENSOR_SIMULATION=false
SENSOR_INTERVAL_MS=2000
LIVE_TELEMETRY_STALE_MS=30000
MQTT_BROKER_URL=mqtts://your-mqtt-broker.example:8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=kavach-backend-prod
MQTT_KEEPALIVE=60
MQTT_RECONNECT_MS=5000
DEVICE_SECRET=replace-with-device-shared-secret
DEVICE_OFFLINE_AFTER_MS=120000
DEVICE_HEARTBEAT_MONITOR_MS=30000

OPENAI_API_KEY=
AI_PROVIDER=offline
OPENAI_MODEL=gpt-4o-mini

ENERGY_COST_PER_KWH=0.12
CARBON_KG_PER_KWH=0.42
DOWNTIME_COST_PER_HOUR=5000

COMPANY_NAME=KAVACH Industrial Operations
COMPANY_SITE=Primary Plant
COMPANY_INDUSTRY=Manufacturing
COMPANY_TIMEZONE=Asia/Kolkata

BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE_ENABLED=false
BACKUP_SCHEDULE_INTERVAL_MS=86400000
BACKUP_RESTORE_TOKEN=replace-with-maintenance-window-token
AUDIT_RETENTION_DAYS=365
