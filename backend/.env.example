# Copy to backend/.env for local development. Never commit real secrets.
# In production the boot guard refuses a placeholder/short (<32 char) secret or
# a wildcard CORS origin.

NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/kavach

# Auth (HS256). Generate with `openssl rand -hex 32`.
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=replace-with-a-second-random-secret-at-least-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Explicit browser origin(s) for CORS (comma-separated). Never `*` in production.
CORS_ORIGIN=http://localhost:3000

# Dev-only telemetry simulator. Off by default; sim readings are labelled `sim`
# and never counted as live when off.
ENABLE_SENSOR_SIMULATION=false
SENSOR_INTERVAL_MS=1000

# MQTT ingest — the only live telemetry source. Set IOT_ENABLED=true to connect.
IOT_ENABLED=false
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=kavach-backend
MQTT_KEEPALIVE=60

# Shared secret every device must present to publish telemetry. Ingest fails
# CLOSED: if this is unset, all device telemetry is rejected (no fail-open).
DEVICE_SECRET=replace-with-device-shared-secret

# Rate limiting / brute-force protection.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=25
BRUTE_FORCE_WINDOW_MS=900000
BRUTE_FORCE_MAX_FAILURES=8
