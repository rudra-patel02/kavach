NODE_ENV=production
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/<database>
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=replace-with-a-second-random-secret-at-least-32-characters
CORS_ORIGIN=https://your-vercel-app.vercel.app
CORS_CREDENTIALS=true
IOT_ENABLED=true
MQTT_BROKER_URL=mqtt://mqtt:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=kavach-backend-prod
MQTT_KEEPALIVE=60
DEVICE_SECRET=replace-with-device-shared-secret
# Prefer same-origin /api and /socket.io through Next.js/nginx rewrites where available.
NEXT_PUBLIC_API_URL=
# Leave blank for same-origin Docker/nginx deployments; set to backend HTTPS URL for split hosting.
NEXT_PUBLIC_SOCKET_URL=https://your-backend-service.onrender.com
API_URL=https://your-backend-service.onrender.com
