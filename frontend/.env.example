# Prefer same-origin /api requests through Next.js rewrites to avoid browser CORS failures.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SOCKET_URL=https://your-backend-service.onrender.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Build-time backend URL for Next.js API rewrites.
API_URL=https://your-backend-service.onrender.com
