    rest --> ai["AI Engine + Predictive Services"]
    rest --> iot["IoT Controllers"]
    rest --> reports["Reports, Audit, Backup"]
  end

  subgraph data["Persistence"]
    auth --> mongo["MongoDB Atlas"]
